# Performance Optimizations for i3 Processor
# Copy these to .env for maximum performance on low-end hardware

# Use file-based sessions instead of database
SESSION_DRIVER=file

# Use sync queue driver instead of database polling  
QUEUE_CONNECTION=sync

# Disable activity logging for better performance
ACTIVITY_LOGGER_ENABLED=false

# Enable caching
CACHE_DRIVER=file

# Use PHP built-in session handler
SESSION_COOKIE_SECURE=false

# Disable query logging in production
APP_DEBUG=false

# Disable telescope in production
TELESCOPE_ENABLED=false

# Use efficient database driver
DB_CONNECTION=mysql

# Connection pooling timeout
DB_PERSISTENT=true
